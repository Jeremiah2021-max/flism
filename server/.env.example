# =============================================
# Flism — Required Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# =============================================

# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/flism

# JWT signing secret — use a long random string (required in production)
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Set to "production" when deploying (required)
NODE_ENV=production

# Port the Express server listens on (optional — defaults to 5000)
# Most platforms (Railway, Render, Heroku) set this automatically
PORT=5000

# -----------------------------------------------
# Mobile app — only needed for native Android/iOS builds
# Set this to your deployed backend URL so the APK/IPA can reach the API
# Not needed for the web version (it uses relative URLs through Express)
# -----------------------------------------------
EXPO_PUBLIC_API_URL=https://your-production-domain.com

# -----------------------------------------------
# Paystack Payment Gateway
# Get your keys from https://dashboard.paystack.co/
# -----------------------------------------------
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

# Admin Account (optional - for seeding default admin)
# If not set, use the create-admin.js script instead
# -----------------------------------------------
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourSecurePassword123!
ADMIN_NAME=Admin Name

# Logging level (optional - defaults to 'info')
# Options: error, warn, info, http, verbose, debug, silly
# -----------------------------------------------
LOG_LEVEL=info
